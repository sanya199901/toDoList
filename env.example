# ============================================
# .env — Environment Variables
# ============================================
# ⚠️ NEVER commit this file to GitHub!
# It contains sensitive information like passwords and secret keys
# Make sure .env is listed in your .gitignore file

# --- MySQL Database ---
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_NAME=todo_db

# --- JWT Settings ---
SECRET_KEY=your_super_secret_key_change_this_to_something_random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
